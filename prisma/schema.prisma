generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Court {
  id          String    @id @default(cuid())
  name        String
  type        String    // "standard" (4er) or "double" (Doppel)
  pricePerHour Float
  description String?
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id              String   @id @default(cuid())
  court           Court    @relation(fields: [courtId], references: [id])
  courtId         String
  date            DateTime
  startTime       Int      // Hour (8-23)
  endTime         Int      // Hour (9-24)
  customerName    String
  customerEmail   String
  customerPhone   String?
  totalPrice      Float
  status          String   @default("pending") // pending, confirmed, cancelled
  stripePaymentId String?
  easybillInvoiceId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
